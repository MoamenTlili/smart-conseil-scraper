# ==============================================================================
# ENVIRONMENT VARIABLES EXAMPLE FILE (.env.example)
# ==============================================================================
# For security reasons and following development best practices, the actual 
# file containing real credentials (.env) is ignored by Git via .gitignore. 
# Passwords and database access keys should never be committed to version control.
# 
# INSTRUCTIONS FOR THE REVIEWER / DEVELOPER:
# 1. Create a new file named ".env" in the root directory of the project.
# 2. Copy the variable format below into this new ".env" file.
# 3. Replace the placeholder values with the actual MongoDB connection URI 
#    (which has been securely provided to you via email).
# ==============================================================================

MONGO_URI=mongodb+srv://<USERNAME>:<PASSWORD>@<CLUSTER_NAME>.mongodb.net/?appName=<APP_NAME>
